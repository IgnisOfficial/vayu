# Application settings
APP_NAME=Coder Framework
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/vayu

# Database settings
DB_TYPE=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=my_database
DB_USERNAME=root
DB_PASSWORD=secret

# JWT settings
JWT_SECRET=your-secret-key-change-in-production
JWT_TTL=3600

# CORS settings
CORS_ORIGINS=*
