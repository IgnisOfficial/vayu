#!/usr/bin/env php
<?php

define('__BASEDIR__', __DIR__);

$autoloadPath = __DIR__ . '/vendor/autoload.php';
if (file_exists($autoloadPath)) {
    require $autoloadPath;
    $dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
    $dotenv->safeLoad();
}

require __DIR__ . '/config/env.php';

$framework = require __DIR__ . '/config/framework.php';

require __DIR__ . '/core/Console/SetupCommand.php';
require __DIR__ . '/core/Console/RunCommand.php';

$command = $argv[1] ?? null;

$commands = [
    'run'   => 'Start the development server',
    'setup' => 'Run the interactive setup wizard',
];

if ($command === null || $command === 'help' || $command === '--help') {
    echo PHP_EOL;
    echo "  \033[1m{$framework['name']}\033[0m v{$framework['version']}" . PHP_EOL;
    echo PHP_EOL;
    echo "  \033[33mUsage:\033[0m" . PHP_EOL;
    echo "    php vayu <command> [options]" . PHP_EOL;
    echo PHP_EOL;
    echo "  \033[33mAvailable commands:\033[0m" . PHP_EOL;
    foreach ($commands as $name => $description) {
        echo "    \033[32m{$name}\033[0m" . str_repeat(' ', 12 - strlen($name)) . $description . PHP_EOL;
    }
    echo PHP_EOL;
    exit(0);
}

match ($command) {
    'run'   => (new RunCommand(__DIR__, $framework))->run(array_slice($argv, 2)),
    'setup' => (new SetupCommand(__DIR__, $framework))->run(),
    default => (function () use ($command) {
        echo PHP_EOL;
        echo "  \033[31mUnknown command: {$command}\033[0m" . PHP_EOL;
        echo "  Run \033[33mphp vayu help\033[0m to see available commands." . PHP_EOL;
        echo PHP_EOL;
        exit(1);
    })(),
};
